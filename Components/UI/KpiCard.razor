@* Components/UI/KpiCard.razor *@
<div class="gp-kpi gp-kpi-@ColorName">
    <div class="gp-kpi-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            @((MarkupString)IconSvgPath)
        </svg>
    </div>
    <div>
        <div class="gp-kpi-label">@Title</div>
        <div class="gp-kpi-value">@Value</div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Value { get; set; } = "";
    // ColorName: "green", "red", "blue", "amber"
    [Parameter] public string ColorName { get; set; } = "green";
    // Pass the inner SVG path/shape string e.g. "<path d='...'/>..."
    [Parameter] public string IconSvgPath { get; set; } = "";
}