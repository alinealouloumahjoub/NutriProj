@page "/edit-recipe"
@page "/edit-recipe/{Id:int}"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@using NutriProj.Models
@using NutriProj.Enums
@using NutriProj.Services_Interfaces
@inject IRecipeService RecipeService
@inject IIngredientService IngredientService
@inject IMealSlotService MealSlotService
@inject IUnitService UnitService
@inject IRecipeIngredientService RecipeIngredientService
@inject NavigationManager NavigationManager

<PageTitle>@(Id.HasValue ? "Edit Recipe" : "Add Recipe")</PageTitle>

<h3>@(Id.HasValue ? "Edit Recipe" : "New Recipe")</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (currentRecipe == null)
{
    <p><em>Loading form...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header">Recipe Details</div>
                <div class="card-body">
                    <EditForm Model="currentRecipe" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger" />

                        <div class="mb-3">
                            <label class="form-label">Recipe Name</label>
                            <InputText @bind-Value="currentRecipe.RecipeName" class="form-control" />
                            <ValidationMessage For="@(() => currentRecipe.RecipeName)" class="text-danger" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Cuisine Type</label>
                            <InputSelect @bind-Value="currentRecipe.TypeKitchen" class="form-select">
                                @foreach (var kt in Enum.GetValues<KitchenType>())
                                {
                                    <option value="@kt">@kt</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Servings</label>
                            <InputNumber @bind-Value="currentRecipe.Servings" class="form-control" />
                            <ValidationMessage For="@(() => currentRecipe.Servings)" class="text-danger" />
                        </div>

                        <div class="row">
                            <div class="col mb-3">
                                <label class="form-label">Prep Time (min)</label>
                                <InputNumber @bind-Value="currentRecipe.TimePreparation" class="form-control" />
                            </div>
                            <div class="col mb-3">
                                <label class="form-label">Cook Time (min)</label>
                                <InputNumber @bind-Value="currentRecipe.TimeCooking" class="form-control" />
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary">Save Recipe</button>
                        <button type="button" class="btn btn-secondary ms-2" @onclick="Cancel">Cancel</button>
                    </EditForm>
                </div>
            </div>
        </div>

        @if (Id.HasValue)
        {
            <div class="col-md-6">
                @* Categories section *@
                <div class="card shadow-sm mb-4">
                    <div class="card-header">Categories (Meal Slots)</div>
                    <div class="card-body">
                        @foreach (var cat in currentRecipe.RecipeCategories)
                        {
                            <span class="badge bg-secondary me-1">
                                @cat.MealSlot?.Name
                                <button class="btn-close btn-close-white ms-1"
                                        style="font-size:0.6rem"
                                        @onclick="() => RemoveCategory(cat.IdCategory)"></button>
                            </span>
                        }
                        <div class="input-group mt-2">
                            <select class="form-select" @bind="selectedSlotId">
                                <option value="0">-- Add category --</option>
                                @foreach (var slot in mealSlots)
                                {
                                    <option value="@slot.IdMealSlot">@slot.Name</option>
                                }
                            </select>
                            <button class="btn btn-outline-secondary" @onclick="AddCategory">Add</button>
                        </div>
                    </div>
                </div>

                @* Ingredients section *@
                <div class="card shadow-sm mb-4">
                    <div class="card-header">
                        Ingredients
                        <span class="float-end text-success fw-bold">
                            Total: @currentRecipe.TotalCalories.ToString("F0") kcal |
                            Per serving: @currentRecipe.CaloriesPerServing.ToString("F0") kcal
                        </span>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm">
                            <thead>
                                <tr><th>Ingredient</th><th>Qty</th><th>Unit</th><th>kcal</th><th></th></tr>
                            </thead>
                            <tbody>
                                @foreach (var ri in currentRecipe.RecipeIngredients)
                                {
                                    <tr>
                                        <td>@ri.Ingredient?.NameIng</td>
                                        <td>@ri.Quantity</td>
                                        <td>@ri.Unit?.Name</td>
                                        <td>@(((ri.Quantity * (ri.Unit?.GramEquivalent ?? 1) / 100.0) * (ri.Ingredient?.CaloriesPer100g ?? 0)).ToString("F0"))</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-danger"
                                                    @onclick="() => RemoveIngredient(ri.IdRecIng)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <div class="row g-2 mt-2">
                            <div class="col-md-5">
                                <select class="form-select" @bind="newIngredientId">
                                    <option value="0">-- Select ingredient --</option>
                                    @foreach (var ing in allIngredients)
                                    {
                                        <option value="@ing.IdIng">@ing.NameIng</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <input type="number" class="form-control" @bind="newQuantity" placeholder="Qty" min="0.1" step="0.1" />
                            </div>
                            <div class="col-md-3">
                                <select class="form-select" @bind="newUnitId">
                                    <option value="0">-- Unit --</option>
                                    @foreach (var u in allUnits)
                                    {
                                        <option value="@u.IdUnit">@u.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <button class="btn btn-success w-100" @onclick="AddIngredient">Add</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public int? Id { get; set; }

    private Recipe? currentRecipe;
    private List<Ingredient> allIngredients = new();
    private List<Unit> allUnits = new();
    private List<MealSlot> mealSlots = new();
    private string? errorMessage;

    private int selectedSlotId = 0;
    private int newIngredientId = 0;
    private double newQuantity = 1;
    private int newUnitId = 0;

    protected override async Task OnInitializedAsync()
    {
        allIngredients = await IngredientService.GetAllIngredients();
        allUnits = await UnitService.GetAllUnits();
        mealSlots = await MealSlotService.GetAllMealSlots();

        if (Id.HasValue)
            currentRecipe = await RecipeService.GetRecipeById(Id.Value);

        if (currentRecipe == null)
            currentRecipe = new Recipe();
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            if (Id.HasValue)
                await RecipeService.UpdateRecipe(currentRecipe!);
            else
            {
                await RecipeService.AddRecipe(currentRecipe!);
                // Redirect to edit page so user can add ingredients
                NavigationManager.NavigateTo($"/edit-recipe/{currentRecipe!.IdRcp}");
                return;
            }
            NavigationManager.NavigateTo("/recipes");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/recipes");
    }

    private async Task AddCategory()
    {
        if (selectedSlotId == 0) return;
        try
        {
            await RecipeService.AddCategory(Id!.Value, selectedSlotId);
            currentRecipe = await RecipeService.GetRecipeById(Id.Value);
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task RemoveCategory(int categoryId)
    {
        try
        {
            await RecipeService.RemoveCategory(categoryId);
            currentRecipe = await RecipeService.GetRecipeById(Id!.Value);
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task AddIngredient()
    {
        if (newIngredientId == 0 || newUnitId == 0 || newQuantity <= 0) return;
        try
        {
            await RecipeIngredientService.Add(Id!.Value, newIngredientId, newQuantity, newUnitId);
            currentRecipe = await RecipeService.GetRecipeById(Id.Value);
            newIngredientId = 0;
            newQuantity = 1;
            newUnitId = 0;
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task RemoveIngredient(int recipeIngredientId)
    {
        try
        {
            await RecipeIngredientService.Remove(recipeIngredientId);
            currentRecipe = await RecipeService.GetRecipeById(Id!.Value);
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }
}