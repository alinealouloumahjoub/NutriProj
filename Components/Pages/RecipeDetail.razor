@page "/recipe/{Id:int}"
@rendermode InteractiveServer
@inject IRecipeService RecipeService

<PageTitle>@(currentRecipe?.RecipeName ?? "Recipe") — GreenPlate</PageTitle>

@if (currentRecipe == null)
{
    <div class="gp-loading">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="gp-spin"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
        Loading recipe...
    </div>
}
else
{
    <div style="display:grid;grid-template-columns:1fr 1.2fr;gap:2rem;align-items:start;">
        <div>
            @if (!string.IsNullOrEmpty(currentRecipe.ImagePath))
            {
                <img src="@currentRecipe.ImagePath" style="width:100%;border-radius:var(--gp-radius);box-shadow:var(--gp-shadow-hover);object-fit:cover;max-height:380px;" />
            }
            else
            {
                <div style="width:100%;height:300px;border-radius:var(--gp-radius);background:var(--gp-green-light);border:1px solid var(--gp-green-border);display:flex;align-items:center;justify-content:center;color:var(--gp-text-faint);">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                </div>
            }

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-top:1.25rem;">
                <div class="gp-kpi gp-kpi-green" style="padding:1rem;">
                    <div class="gp-kpi-icon" style="width:36px;height:36px;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2c0 6-8 10-8 14a8 8 0 0 0 16 0c0-4-8-8-8-14z"/></svg>
                    </div>
                    <div>
                        <div class="gp-kpi-label">Total kcal</div>
                        <div class="gp-kpi-value" style="font-size:1.2rem;">@ScaledTotalCalories.ToString("F0")</div>
                    </div>
                </div>
                <div class="gp-kpi gp-kpi-blue" style="padding:1rem;">
                    <div class="gp-kpi-icon" style="width:36px;height:36px;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </div>
                    <div>
                        <div class="gp-kpi-label">Per serving</div>
                        <div class="gp-kpi-value" style="font-size:1.2rem;">@(currentServings > 0 ? (ScaledTotalCalories / currentServings).ToString("F0") : "0")</div>
                    </div>
                </div>
            </div>
        </div>

        <div>
            <h2 style="font-family:'Playfair Display',serif;font-size:2rem;font-weight:700;color:var(--gp-text-dark);margin:0 0 0.5rem;">@currentRecipe.RecipeName</h2>

            <div style="display:flex;gap:0.75rem;margin-bottom:1rem;flex-wrap:wrap;font-size:0.85rem;color:var(--gp-text-muted);">
                <span style="display:flex;align-items:center;gap:0.3rem;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                    @currentRecipe.TypeKitchen
                </span>
                <span style="display:flex;align-items:center;gap:0.3rem;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    @currentRecipe.TimePreparation min prep · @currentRecipe.TimeCooking min cook
                </span>
            </div>

            <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1.25rem;">
                @foreach (var cat in currentRecipe.RecipeCategories)
                {
                    <span class="gp-badge gp-badge-green">@cat.MealSlot?.Name</span>
                }
            </div>

            @if (!string.IsNullOrEmpty(currentRecipe.Description))
            {
                <p style="color:var(--gp-text-muted);line-height:1.7;margin-bottom:1.25rem;">@currentRecipe.Description</p>
            }

            <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;padding:1rem;background:var(--gp-green-light);border-radius:var(--gp-radius-sm);border:1px solid var(--gp-green-border);">
                <span style="font-weight:500;color:var(--gp-text-dark);">Servings:</span>
                <button class="gp-btn gp-btn-outline-green" style="padding:0.3rem 0.7rem;" @onclick="Decrement">−</button>
                <span style="font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;color:var(--gp-text-dark);min-width:2rem;text-align:center;">@currentServings</span>
                <button class="gp-btn gp-btn-outline-green" style="padding:0.3rem 0.7rem;" @onclick="Increment">+</button>
            </div>

            <div class="gp-section-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 2l1.5 14.5L12 22l7.5-5.5L21 2"/></svg>
                Ingredients
            </div>
            <table class="gp-table" style="margin-bottom:1.5rem;">
                <thead>
                    <tr><th></th><th>Ingredient</th><th>Quantity</th><th>Unit</th></tr>
                </thead>
                <tbody>
                    @foreach (var ri in currentRecipe.RecipeIngredients)
                    {
                        var scaledQty = ri.Quantity * currentServings / (double)currentRecipe.Servings;
                        <tr>
                            <td style="width:40px;">
                                @if (!string.IsNullOrEmpty(ri.Ingredient?.ImagePath))
                                {
                                    <img src="@ri.Ingredient.ImagePath" style="width:32px;height:32px;object-fit:cover;border-radius:6px;" />
                                }
                            </td>
                            <td style="font-weight:500;color:var(--gp-text-dark);">@ri.Ingredient?.NameIng</td>
                            <td><strong>@scaledQty.ToString("F1")</strong></td>
                            <td><span class="gp-badge gp-badge-gray">@ri.Unit?.Name</span></td>
                        </tr>
                    }
                </tbody>
            </table>

            <a href="/recipes" class="gp-btn gp-btn-outline-gray">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                Back to Recipes
            </a>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private Recipe? currentRecipe;
    private int currentServings = 4;

    private double ScaledTotalCalories => currentRecipe == null ? 0 :
        currentRecipe.RecipeIngredients.Sum(ri =>
            (ri.Quantity * currentServings / (double)currentRecipe.Servings)
            * (ri.Unit?.GramEquivalent ?? 1) / 100.0
            * (ri.Ingredient?.CaloriesPer100g ?? 0));

    protected override async Task OnInitializedAsync()
    {
        currentRecipe = await RecipeService.GetRecipeById(Id);
        if (currentRecipe != null) currentServings = currentRecipe.Servings;
    }

    private void Increment() { if (currentServings < 50) currentServings++; }
    private void Decrement() { if (currentServings > 1)  currentServings--; }
}