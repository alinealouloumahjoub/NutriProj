@page "/login"
@page "/"
@layout EmptyLayout

<HeadContent>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        .gp-auth-wrapper {
            display: flex;
            min-height: 100vh;
            font-family: 'DM Sans', sans-serif;
        }

        .gp-auth-left {
            flex: 1;
            background: linear-gradient(150deg, #1a5c35 0%, #2d8653 40%, #1e7a45 100%);
            padding: 3rem 3.5rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
        }

        .gp-auth-left::before {
            content: '';
            position: absolute;
            top: -80px; right: -80px;
            width: 320px; height: 320px;
            border-radius: 50%;
            background: rgba(255,255,255,0.06);
        }

        .gp-auth-left::after {
            content: '';
            position: absolute;
            bottom: -60px; left: -60px;
            width: 240px; height: 240px;
            border-radius: 50%;
            background: rgba(255,255,255,0.04);
        }

        .gp-brand {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            color: white;
        }

        .gp-logo-icon { width: 40px; height: 40px; }

        .gp-brand-name {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            font-weight: 700;
        }

        .gp-auth-tagline { color: white; position: relative; z-index: 1; }

        .gp-auth-tagline h1 {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            font-weight: 700;
            line-height: 1.15;
            margin-bottom: 1.25rem;
        }

        .gp-auth-tagline h1 em { font-style: italic; color: #a8f0c6; }

        .gp-auth-tagline p {
            font-size: 1rem;
            line-height: 1.7;
            color: rgba(255,255,255,0.8);
            max-width: 340px;
        }

        .gp-features { display: flex; flex-direction: column; gap: 0.875rem; position: relative; z-index: 1; }

        .gp-feature-item {
            display: flex;
            align-items: center;
            gap: 0.625rem;
            color: rgba(255,255,255,0.9);
            font-size: 0.9rem;
        }

        .gp-feature-item svg { width: 18px; height: 18px; flex-shrink: 0; color: #a8f0c6; }

        .gp-auth-right {
            width: 480px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f8faf9;
            padding: 2rem;
        }

        .gp-auth-card { width: 100%; max-width: 380px; }

        .gp-auth-card-header { margin-bottom: 2rem; }

        .gp-auth-card-header h2 {
            font-family: 'Playfair Display', serif;
            font-size: 1.875rem;
            font-weight: 700;
            color: #1a2e20;
            margin-bottom: 0.375rem;
        }

        .gp-auth-card-header p { color: #6b7c72; font-size: 0.9rem; }

        .gp-alert {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-size: 0.875rem;
            margin-bottom: 1.25rem;
        }

        .gp-alert svg { width: 16px; height: 16px; flex-shrink: 0; }
        .gp-alert-danger  { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
        .gp-alert-success { background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; }

        .gp-form { display: flex; flex-direction: column; gap: 1.125rem; }
        .gp-field { display: flex; flex-direction: column; gap: 0.4rem; }

        .gp-label {
            font-size: 0.8rem;
            font-weight: 500;
            color: #374841;
            letter-spacing: 0.03em;
            text-transform: uppercase;
        }

        .gp-input-wrapper { position: relative; }

        .gp-input-icon {
            position: absolute;
            left: 0.875rem;
            top: 50%;
            transform: translateY(-50%);
            width: 16px; height: 16px;
            color: #9aad9e;
            pointer-events: none;
        }

        .gp-input {
            width: 100%;
            padding: 0.75rem 0.875rem 0.75rem 2.625rem;
            border: 1.5px solid #d4e0d7;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.925rem;
            color: #1a2e20;
            background: white;
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

        .gp-input:focus {
            border-color: #2d8653;
            box-shadow: 0 0 0 3px rgba(45,134,83,0.12);
        }

        .gp-input::placeholder { color: #b0bdb4; }

        .gp-btn-primary {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            margin-top: 0.5rem;
            padding: 0.875rem 1.5rem;
            background: linear-gradient(135deg, #2d8653, #1e6e42);
            color: white;
            border: none;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.975rem;
            font-weight: 500;
            cursor: pointer;
            transition: transform 0.15s, box-shadow 0.15s;
            box-shadow: 0 4px 14px rgba(30,110,66,0.35);
        }

        .gp-btn-primary svg { width: 16px; height: 16px; }
        .gp-btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(30,110,66,0.4); }
        .gp-btn-primary:active { transform: translateY(0); }

        .gp-auth-footer {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.875rem;
            color: #6b7c72;
        }

        .gp-auth-footer a { color: #2d8653; font-weight: 500; text-decoration: none; }
        .gp-auth-footer a:hover { text-decoration: underline; }

        @@media (max-width: 768px) {
            .gp-auth-left { display: none; }
            .gp-auth-right { width: 100%; }
        }
    </style>
</HeadContent>

<div class="gp-auth-wrapper">
    <div class="gp-auth-left">
        <div class="gp-brand">
            <svg class="gp-logo-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="24" cy="24" r="23" stroke="white" stroke-width="2" fill="none"/>
                <path d="M14 28c0-5.5 4.5-10 10-10s10 4.5 10 10" stroke="white" stroke-width="2" stroke-linecap="round"/>
                <path d="M24 18v-6M20 15l4-3 4 3" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="24" cy="31" r="4" fill="white" opacity="0.9"/>
                <path d="M17 34h14" stroke="white" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <span class="gp-brand-name">GreenPlate</span>
        </div>
        <div class="gp-auth-tagline">
            <h1>Nourish your<br /><em>body &amp; soul</em></h1>
            <p>Plan your meals, discover wholesome recipes, and eat mindfully — every single day.</p>
        </div>
        <div class="gp-features">
            <div class="gp-feature-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
                Smart weekly meal planner
            </div>
            <div class="gp-feature-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
                Calorie tracking per serving
            </div>
            <div class="gp-feature-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
                Hundreds of curated recipes
            </div>
        </div>
    </div>

    <div class="gp-auth-right">
        <div class="gp-auth-card">
            <div class="gp-auth-card-header">
                <h2>Welcome back</h2>
                <p>Sign in to your GreenPlate account</p>
            </div>

            @if (!string.IsNullOrEmpty(Error))
            {
                <div class="gp-alert gp-alert-danger">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    @Error
                </div>
            }
            @if (!string.IsNullOrEmpty(Success))
            {
                <div class="gp-alert gp-alert-success">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
                    @Success
                </div>
            }

            <form method="post" action="/api/auth/login" data-enhance="false" class="gp-form">
                <div class="gp-field">
                    <label class="gp-label">Email address</label>
                    <div class="gp-input-wrapper">
                        <svg class="gp-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        <input type="email" name="email" class="gp-input" placeholder="you@example.com" required />
                    </div>
                </div>
                <div class="gp-field">
                    <label class="gp-label">Password</label>
                    <div class="gp-input-wrapper">
                        <svg class="gp-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        <input type="password" name="password" class="gp-input" placeholder="••••••••" required />
                    </div>
                </div>
                <button type="submit" class="gp-btn-primary">
                    Sign in
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </button>
            </form>

            <p class="gp-auth-footer">
                Don't have an account? <a href="/inscription">Create one free</a>
            </p>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    [SupplyParameterFromQuery]
    public string? Success { get; set; }
}