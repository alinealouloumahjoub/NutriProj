@page "/edit-ingredient"
@page "/edit-ingredient/{Id:int}"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject IIngredientService IngredientService
@inject NavigationManager NavigationManager

<PageTitle>@(Id.HasValue ? "Edit Ingredient" : "New Ingredient") — GreenPlate</PageTitle>

<div class="gp-page-header">
    <div>
        <h2>@(Id.HasValue ? "Edit Ingredient" : "New Ingredient")</h2>
        <p>@(Id.HasValue ? "Update ingredient details" : "Add a new ingredient to the pantry")</p>
    </div>
    <a href="/ingredients" class="gp-btn gp-btn-outline-gray">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back
    </a>
</div>

@if (currentIngredient == null)
{
    <div class="gp-loading">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="gp-spin"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
        Loading...
    </div>
}
else
{
    <div class="gp-card" style="max-width:540px;">
        <div class="gp-card-body">
            <EditForm Model="currentIngredient" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary class="gp-alert gp-alert-danger" />

                <div class="mb-4">
                    <label class="gp-form-label">Ingredient Name</label>
                    <InputText @bind-Value="currentIngredient.NameIng" class="gp-form-control" placeholder="e.g. Chickpeas" />
                    <ValidationMessage For="@(() => currentIngredient.NameIng)" class="gp-alert gp-alert-danger" style="padding:0.4rem 0.75rem;margin-top:0.375rem;" />
                </div>

                <div class="mb-4">
                    <label class="gp-form-label">Calories per 100g</label>
                    <InputNumber @bind-Value="currentIngredient.CaloriesPer100g" class="gp-form-control" placeholder="0" />
                    <ValidationMessage For="@(() => currentIngredient.CaloriesPer100g)" class="gp-alert gp-alert-danger" style="padding:0.4rem 0.75rem;margin-top:0.375rem;" />
                </div>

                <div class="mb-4">
                    <label class="gp-form-label">Image (optional)</label>
                    <InputFile OnChange="HandleImageUpload" class="gp-form-control" accept="image/*" style="padding:0.5rem;" />
                    @if (!string.IsNullOrEmpty(currentIngredient.ImagePath))
                    {
                        <img src="@currentIngredient.ImagePath" class="mt-2 rounded" style="height:90px;border:1px solid var(--gp-green-border);border-radius:8px;" />
                    }
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="gp-alert gp-alert-danger">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        @errorMessage
                    </div>
                }

                <div style="display:flex;justify-content:flex-end;gap:0.625rem;margin-top:0.5rem;">
                    <a href="/ingredients" class="gp-btn gp-btn-outline-gray">Cancel</a>
                    <button type="submit" class="gp-btn gp-btn-green">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v14a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                        Save Ingredient
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public int? Id { get; set; }
    private Ingredient? currentIngredient;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        currentIngredient = Id.HasValue
            ? await IngredientService.GetIngredientById(Id.Value)
            : new Ingredient();
        currentIngredient ??= new Ingredient();
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        var uploadPath = Path.Combine("wwwroot", "uploads", "ingredients");
        Directory.CreateDirectory(uploadPath);
        var fileName = $"{Guid.NewGuid()}{Path.GetExtension(file.Name)}";
        var fullPath = Path.Combine(uploadPath, fileName);
        await using var stream = new FileStream(fullPath, FileMode.Create);
        await file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).CopyToAsync(stream);
        currentIngredient!.ImagePath = $"/uploads/ingredients/{fileName}";
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            if (Id.HasValue) await IngredientService.UpdateIngredient(currentIngredient!);
            else             await IngredientService.AddIngredient(currentIngredient!);
            NavigationManager.NavigateTo("/ingredients");
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }
}