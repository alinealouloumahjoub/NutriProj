@page "/meal-planner"
@rendermode InteractiveServer
@using NutriProj.Models
@using NutriProj.Enums
@using NutriProj.Services_Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@inject IMealPlannerService MealPlannerService
@inject IRecipeService RecipeService
@inject IMealSlotService MealSlotService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Meal Planner</PageTitle>

<h1>Meal Planner</h1>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@* Step 1: Week setup *@
<div class="card shadow-sm mb-4">
    <div class="card-header">Week Plan Setup</div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Week starting (Monday)</label>
                <input type="date" class="form-control" @bind="weekStartDate" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Daily calorie target</label>
                <input type="number" class="form-control" @bind="dailyCalTarget" min="500" max="5000" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary" @onclick="LoadOrCreatePlan">Load / Create</button>
            </div>
        </div>
    </div>
</div>

@if (currentPlan != null)
{
    @* Step 2: Add a meal to a specific slot *@
    <div class="card shadow-sm mb-4">
        <div class="card-header">Add Meal to Plan</div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-2">
                    <select class="form-select" @bind="selectedDay">
                        @foreach (var day in Enum.GetValues<DayOfWeekEnum>())
                        {
                            <option value="@day">@day</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select" @bind="selectedSlotId">
                        @foreach (var slot in mealSlots)
                        {
                            <option value="@slot.IdMealSlot">@slot.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-5">
                    <select class="form-select" @bind="selectedRecipeId">
                        <option value="0">-- Select recipe --</option>
                        @foreach (var r in allRecipes)
                        {
                            <option value="@r.IdRcp">@r.RecipeName (@r.TotalCalories.ToString("F0") kcal)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-success w-100" @onclick="AddMeal">Add</button>
                </div>
            </div>
        </div>
    </div>

    @* Step 3: Weekly grid view *@
    <div class="card shadow-sm mb-4">
        <div class="card-header">
            Weekly Overview — Week of @currentPlan.WeekStartDate.ToString("dd MMM yyyy")
            <span class="float-end">
                Total: <strong>@weekTotalCal.ToString("F0") kcal</strong> |
                Target: <strong>@(currentPlan.DailyCaloriesTarget * 7) kcal</strong>
            </span>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered text-center">
                    <thead class="table-dark">
                        <tr>
                            <th>Meal</th>
                            @foreach (var day in Enum.GetValues<DayOfWeekEnum>())
                            {
                                <th>@day</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var slot in mealSlots)
                        {
                            <tr>
                                <td class="fw-bold">@slot.Name</td>
                                @foreach (var day in Enum.GetValues<DayOfWeekEnum>())
                                {
                                    var detail = weekDetails.FirstOrDefault(d => d.Day == day && d.IdMealSlot == slot.IdMealSlot);
                                    <td>
                                        @if (detail != null)
                                        {
                                            <span class="badge bg-success">@detail.Recipe?.RecipeName</span>
                                            <br />
                                            <small class="text-muted">@detail.Recipe?.TotalCalories.ToString("F0") kcal</small>
                                            <br />
                                            <button class="btn btn-sm btn-outline-danger mt-1"
                                                    @onclick="() => RemoveMeal(detail.IdDetail)">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                        <tr class="table-light fw-bold">
                            <td>Total kcal</td>
                            @foreach (var day in Enum.GetValues<DayOfWeekEnum>())
                            {
                                var dayTotal = weekDetails
                                    .Where(d => d.Day == day)
                                    .Sum(d => d.Recipe?.TotalCalories ?? 0);
                                <td class="@(dayTotal > currentPlan.DailyCaloriesTarget ? "text-danger" : "text-success")">
                                    @dayTotal.ToString("F0")
                                </td>
                            }
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private MealPlanner? currentPlan;
    private List<MealPlannerDetail> weekDetails = new();
    private List<MealSlot> mealSlots = new();
    private List<Recipe> allRecipes = new();
    private string? errorMessage;
    private string? userId;

    private DateOnly weekStartDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek + 1));
    private int dailyCalTarget = 2000;
    private DayOfWeekEnum selectedDay = DayOfWeekEnum.Monday;
    private int selectedSlotId = 0;
    private int selectedRecipeId = 0;
    private double weekTotalCal = 0;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        mealSlots = await MealSlotService.GetAllMealSlots();
        allRecipes = await RecipeService.GetAllRecipes();

        if (mealSlots.Any()) selectedSlotId = mealSlots.First().IdMealSlot;
    }

    private async Task LoadOrCreatePlan()
    {
        if (userId == null) { errorMessage = "Please log in first."; return; }
        try
        {
            currentPlan = await MealPlannerService.GetOrCreateWeekPlan(userId, weekStartDate, dailyCalTarget);
            await RefreshWeekDetails();
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task RefreshWeekDetails()
    {
        if (currentPlan == null) return;
        weekDetails = await MealPlannerService.GetWeekDetails(currentPlan.IdPlanner);
        weekTotalCal = await MealPlannerService.GetWeekTotalCalories(currentPlan.IdPlanner);
    }

    private async Task AddMeal()
    {
        if (currentPlan == null || selectedRecipeId == 0) return;
        try
        {
            await MealPlannerService.AddDetail(currentPlan.IdPlanner, selectedRecipeId, selectedDay, selectedSlotId);
            await RefreshWeekDetails();
            selectedRecipeId = 0;
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task RemoveMeal(int detailId)
    {
        try
        {
            await MealPlannerService.RemoveDetail(detailId);
            await RefreshWeekDetails();
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }
}