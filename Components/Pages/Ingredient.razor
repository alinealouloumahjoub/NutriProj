@page "/ingredients"
@rendermode InteractiveServer
@using NutriProj.Models
@using NutriProj.Services_Interfaces
@inject IIngredientService IngredientService
@inject NavigationManager NavigationManager

<PageTitle>Ingredients</PageTitle>

<h1>Ingredients</h1>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<AuthorizeView Roles="Admin">
    <Authorized>
        <button class="btn btn-success mb-3" @onclick="ShowAddForm">
            <i class="bi bi-plus-circle"></i> Add Ingredient
        </button>
    </Authorized>
</AuthorizeView>

@if (showForm)
{
    <div class="card mb-4 shadow-sm">
        <div class="card-header">@(editingIngredient.IdIng == 0 ? "New Ingredient" : "Edit Ingredient")</div>
        <div class="card-body">
            <EditForm Model="editingIngredient" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />

                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <InputText @bind-Value="editingIngredient.NameIng" class="form-control" />
                    <ValidationMessage For="@(() => editingIngredient.NameIng)" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Calories per 100g</label>
                    <InputNumber @bind-Value="editingIngredient.CaloriesPer100g" class="form-control" />
                    <ValidationMessage For="@(() => editingIngredient.CaloriesPer100g)" class="text-danger" />
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
                <button type="button" class="btn btn-secondary ms-2" @onclick="CancelForm">Cancel</button>
            </EditForm>
        </div>
    </div>
}

@if (ingredients == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="mb-3">
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text"
                   @bind="searchText"
                   @bind:event="oninput"
                   class="form-control"
                   placeholder="Search by name..." />
        </div>
    </div>

    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Calories / 100g</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!FilteredIngredients.Any())
            {
                <tr><td colspan="3" class="text-center">No ingredients found.</td></tr>
            }
            else
            {
                @foreach (var ing in FilteredIngredients)
                {
                    <tr>
                        <td>@ing.NameIng</td>
                        <td>@ing.CaloriesPer100g kcal</td>
                        <td>
                            <AuthorizeView Roles="Admin">
                                <Authorized>
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => ShowEditForm(ing)">
                                        <i class="bi bi-pencil"></i> Edit
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => DeleteIngredient(ing.IdIng)">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {
    private List<Ingredient>? ingredients;
    private Ingredient editingIngredient = new();
    private bool showForm = false;
    private string searchText = "";
    private string? errorMessage;

    private List<Ingredient> FilteredIngredients =>
        ingredients?.Where(i => string.IsNullOrEmpty(searchText) ||
                                i.NameIng.Contains(searchText, StringComparison.OrdinalIgnoreCase))
                   .ToList() ?? new();

    protected override async Task OnInitializedAsync()
    {
        await LoadIngredients();
    }

    private async Task LoadIngredients()
    {
        ingredients = await IngredientService.GetAllIngredients();
    }

    private void ShowAddForm()
    {
        editingIngredient = new Ingredient();
        showForm = true;
        errorMessage = null;
    }

    private void ShowEditForm(Ingredient ing)
    {
        editingIngredient = new Ingredient
        {
            IdIng = ing.IdIng,
            NameIng = ing.NameIng,
            CaloriesPer100g = ing.CaloriesPer100g
        };
        showForm = true;
        errorMessage = null;
    }

    private void CancelForm()
    {
        showForm = false;
        errorMessage = null;
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            if (editingIngredient.IdIng == 0)
                await IngredientService.AddIngredient(editingIngredient);
            else
                await IngredientService.UpdateIngredient(editingIngredient);

            showForm = false;
            await LoadIngredients();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private async Task DeleteIngredient(int id)
    {
        try
        {
            await IngredientService.DeleteIngredient(id);
            await LoadIngredients();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}