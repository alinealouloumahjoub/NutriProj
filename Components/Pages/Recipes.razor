@page "/recipes"
@rendermode InteractiveServer
@inject IRecipeService RecipeService
@inject IMealSlotService MealSlotService


<h3>Recipes</h3>

<AuthorizeView Roles="Admin">
    <Authorized>
        <a href="/edit-recipe" class="btn btn-success mb-3">
            <i class="bi bi-plus-circle"></i> Add Recipe
        </a>
    </Authorized>
</AuthorizeView>

<div class="row mb-3 g-2">
    <div class="col-md-4">
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text"
                   @bind="searchText"
                   @bind:event="oninput"
                   class="form-control"
                   placeholder="Search by name..." />
        </div>
    </div>
    <div class="col-md-3">
        <select class="form-select" @bind="selectedKitchenType" @bind:after="Search">
            <option value="">All cuisines</option>
            @foreach (var kt in Enum.GetValues<KitchenType>())
            {
                <option value="@kt">@kt</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <select class="form-select" @bind="selectedMealSlotId" @bind:after="Search">
            <option value="0">All meal types</option>
            @foreach (var slot in mealSlots)
            {
                <option value="@slot.IdMealSlot">@slot.Name</option>
            }
        </select>
    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (recipes == null)
{
    <p><em>Loading...</em></p>
}
else if (!recipes.Any())
{
    <div class="alert alert-info">No recipes found.</div>
}
else
{
    @* Admin view — table with edit/delete *@
    <AuthorizeView Roles="Admin">
        <Authorized>
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Cuisine</th>
                        <th>Servings</th>
                        <th>Total kcal</th>
                        <th>Per Serving</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in recipes)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(r.ImagePath))
                                {
                                    <img src="@r.ImagePath" style="width:50px;height:50px;object-fit:cover;" class="rounded" />
                                }
                            </td>
                            <td>@r.RecipeName</td>
                            <td>@r.TypeKitchen</td>
                            <td>@r.Servings</td>
                            <td>@r.TotalCalories.ToString("F0")</td>
                            <td>@r.CaloriesPerServing.ToString("F0")</td>
                            <td>
                                <a href="/recipe/@r.IdRcp" class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-eye"></i> View
                                </a>
                                <a href="/edit-recipe/@r.IdRcp" class="btn btn-sm btn-outline-primary ms-1">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => DeleteRecipe(r.IdRcp)">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </Authorized>
        <NotAuthorized>
            @* User view — Marmiton-style clickable cards *@
            <div class="row row-cols-1 row-cols-md-3 g-4">
                @foreach (var r in recipes)
                {
                    <div class="col">
                        <a href="/recipe/@r.IdRcp" class="text-decoration-none">
                            <div class="card h-100 shadow-sm recipe-card">
                                @if (!string.IsNullOrEmpty(r.ImagePath))
                                {
                                    <img src="@r.ImagePath" class="card-img-top" style="height:180px;object-fit:cover;" />
                                }
                                else
                                {
                                    <div class="card-img-top d-flex align-items-center justify-content-center bg-light" style="height:180px;">
                                        <i class="bi bi-image text-muted" style="font-size:3rem;"></i>
                                    </div>
                                }
                                <div class="card-body">
                                    <h5 class="card-title text-dark">@r.RecipeName</h5>
                                    <p class="text-muted small">
                                        <i class="bi bi-globe2"></i> @r.TypeKitchen &nbsp;|&nbsp;
                                        <i class="bi bi-clock"></i> @(r.TimePreparation + r.TimeCooking) min
                                    </p>
                                    <div class="d-flex gap-1 mb-2">
                                        @foreach (var cat in r.RecipeCategories)
                                        {
                                            <span class="badge bg-success">@cat.MealSlot?.Name</span>
                                        }
                                    </div>
                                    <p class="text-muted small mb-0">
                                        <i class="bi bi-fire text-danger"></i> @r.CaloriesPerServing.ToString("F0") kcal/serving
                                    </p>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </NotAuthorized>
    </AuthorizeView>
}

@code {
    private List<Recipe>? recipes;
    private List<MealSlot> mealSlots = new();
    private string? errorMessage;
    private string searchText = "";
    private string selectedKitchenType = "";
    private int selectedMealSlotId = 0;

    private string SearchText
    {
        get => searchText;
        set
        {
            searchText = value;
            _ = Search();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        mealSlots = await MealSlotService.GetAllMealSlots();
        await Search();
    }

    private async Task Search()
    {
        try
        {
            KitchenType? kt = string.IsNullOrEmpty(selectedKitchenType)
                ? null
                : Enum.Parse<KitchenType>(selectedKitchenType);

            int? slotId = selectedMealSlotId == 0 ? null : selectedMealSlotId;
            recipes = await RecipeService.SearchRecipesAsync(searchText, kt, slotId, null, null);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private async Task DeleteRecipe(int id)
    {
        try
        {
            await RecipeService.DeleteRecipe(id);
            await Search();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}