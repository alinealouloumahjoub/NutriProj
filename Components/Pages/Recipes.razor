@page "/recipes"
@rendermode InteractiveServer
@inject IRecipeService RecipeService
@inject IMealSlotService MealSlotService

<PageTitle>Recipes — GreenPlate</PageTitle>

<HeadContent>
    <style>
        .gp-filters { display:flex; align-items:center; gap:0.75rem; margin-bottom:1.75rem; flex-wrap:wrap; }
        .gp-thumb { width:44px; height:44px; border-radius:8px; object-fit:cover; border:1px solid #ddeae1; }
        .gp-thumb-placeholder { width:44px; height:44px; border-radius:8px; background:#f5f8f6; border:1px solid #ddeae1; display:flex; align-items:center; justify-content:center; color:#9aad9e; }
        .gp-thumb-placeholder svg { width:18px; height:18px; }
        .gp-action-btns { display:flex; gap:0.375rem; flex-wrap:wrap; }
        .gp-recipe-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:1.25rem; }
        .gp-recipe-card-link { text-decoration:none !important; color:inherit; }
        .gp-recipe-card { background:white; border:1px solid #ddeae1; border-radius:12px; overflow:hidden; transition:box-shadow 0.2s, transform 0.2s; }
        .gp-recipe-card:hover { box-shadow:0 8px 24px rgba(26,46,32,0.12); transform:translateY(-2px); }
        .gp-recipe-card-img { position:relative; height:200px; overflow:hidden; background:#f5f8f6; }
        .gp-recipe-card-img img { width:100%; height:100%; object-fit:cover; transition:transform 0.3s; }
        .gp-recipe-card:hover .gp-recipe-card-img img { transform:scale(1.04); }
        .gp-recipe-card-img-placeholder { width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:#9aad9e; }
        .gp-recipe-card-img-placeholder svg { width:48px; height:48px; }
        .gp-recipe-card-badges { position:absolute; top:0.75rem; left:0.75rem; display:flex; gap:0.375rem; flex-wrap:wrap; }
        .gp-recipe-card-body { padding:1.125rem; }
        .gp-recipe-card-title { font-family:'Playfair Display',serif; font-size:1.05rem; font-weight:600; color:#1a2e20; margin:0 0 0.625rem; line-height:1.3; }
        .gp-recipe-card-meta { display:flex; gap:1rem; font-size:0.8rem; color:#6b7c72; margin-bottom:0.625rem; }
        .gp-recipe-card-meta span { display:flex; align-items:center; gap:0.3rem; }
        .gp-recipe-card-meta svg { width:13px; height:13px; }
        .gp-recipe-card-calories { display:flex; align-items:center; gap:0.375rem; font-size:0.825rem; font-weight:500; color:#2d8653; padding-top:0.625rem; border-top:1px solid #ddeae1; }
        .gp-recipe-card-calories svg { width:13px; height:13px; }
        .gp-spin { animation: gp-spin 1s linear infinite; }
        @@keyframes gp-spin { to { transform: rotate(360deg); } }
    </style>
</HeadContent>

<div class="gp-page-header">
    <div>
        <h2>Recipes</h2>
        <p>Browse, search and discover wholesome meals</p>
    </div>
    <AuthorizeView Roles="Admin">
        <Authorized>
            <a href="/edit-recipe" class="gp-btn gp-btn-green">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add Recipe
            </a>
        </Authorized>
    </AuthorizeView>
</div>

<div class="gp-filters">
    <div class="gp-search-wrapper" style="flex:1;max-width:320px;">
        <svg class="gp-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" @bind="SearchText" @bind:event="oninput" class="gp-form-control gp-search-input" placeholder="Search recipes..." />
    </div>
    <select class="gp-form-control gp-select" style="width:180px;" @bind="selectedKitchenType" @bind:after="Search">
        <option value="">All cuisines</option>
        @foreach (var kt in Enum.GetValues<KitchenType>())
        {
            <option value="@kt">@kt</option>
        }
    </select>
    <select class="gp-form-control gp-select" style="width:180px;" @bind="selectedMealSlotId" @bind:after="Search">
        <option value="0">All meal types</option>
        @foreach (var slot in mealSlots)
        {
            <option value="@slot.IdMealSlot">@slot.Name</option>
        }
    </select>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="gp-alert gp-alert-danger">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        @errorMessage
    </div>
}

@if (recipes == null)
{
    <div class="gp-loading">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="gp-spin"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
        Loading recipes...
    </div>
}
else if (!recipes.Any())
{
    <div class="gp-alert gp-alert-info">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        No recipes found. Try adjusting your filters.
    </div>
}
else
{
    <AuthorizeView Roles="Admin">
        <Authorized>
            @if (!string.IsNullOrEmpty(confirmMessage))
            {
                <div class="gp-modal-backdrop">
                    <div class="gp-modal">
                        <h3 class="gp-modal-title">Delete Recipe</h3>
                        <p class="gp-modal-body">@confirmMessage This action cannot be undone.</p>
                        <div class="gp-modal-footer">
                            <button class="gp-btn gp-btn-outline-gray" @onclick="CancelDelete">Cancel</button>
                            <button class="gp-btn gp-btn-outline-red" @onclick="ConfirmDelete">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                Delete
                            </button>
                        </div>
                    </div>
                </div>
            }
            <div class="gp-card" style="overflow:hidden;">
                <table class="gp-table">
                    <thead>
                        <tr>
                            <th>Image</th><th>Name</th><th>Cuisine</th><th>Servings</th><th>Total kcal</th><th>Per Serving</th><th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in recipes)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(r.ImagePath))
                                    {
                                        <img src="@r.ImagePath" class="gp-thumb" />
                                    }
                                    else
                                    {
                                        <div class="gp-thumb-placeholder"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>
                                    }
                                </td>
                                <td style="font-weight:500;color:var(--gp-text-dark);">@r.RecipeName</td>
                                <td><span class="gp-badge gp-badge-blue">@r.TypeKitchen</span></td>
                                <td>@r.Servings</td>
                                <td style="font-weight:600;">@r.TotalCalories.ToString("F0")</td>
                                <td style="color:var(--gp-text-muted);">@r.CaloriesPerServing.ToString("F0")</td>
                                <td>
                                    <div class="gp-action-btns">
                                        <a href="/recipe/@r.IdRcp" class="gp-btn gp-btn-outline-blue" style="padding:0.35rem 0.75rem;font-size:0.8rem;">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> View
                                        </a>
                                        <a href="/edit-recipe/@r.IdRcp" class="gp-btn gp-btn-outline-green" style="padding:0.35rem 0.75rem;font-size:0.8rem;">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit
                                        </a>
                                        <button class="gp-btn gp-btn-outline-red" style="padding:0.35rem 0.75rem;font-size:0.8rem;" @onclick="() => AskDeleteRecipe(r.IdRcp)">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg> Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="gp-recipe-grid">
                @foreach (var r in recipes)
                {
                    <a href="/recipe/@r.IdRcp" class="gp-recipe-card-link">
                        <div class="gp-recipe-card">
                            <div class="gp-recipe-card-img">
                                @if (!string.IsNullOrEmpty(r.ImagePath))
                                {
                                    <img src="@r.ImagePath" alt="@r.RecipeName" />
                                }
                                else
                                {
                                    <div class="gp-recipe-card-img-placeholder">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                                    </div>
                                }
                                <div class="gp-recipe-card-badges">
                                    @foreach (var cat in r.RecipeCategories)
                                    {
                                        <span class="gp-badge gp-badge-green">@cat.MealSlot?.Name</span>
                                    }
                                </div>
                            </div>
                            <div class="gp-recipe-card-body">
                                <h3 class="gp-recipe-card-title">@r.RecipeName</h3>
                                <div class="gp-recipe-card-meta">
                                    <span>
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                        @(r.TimePreparation + r.TimeCooking) min
                                    </span>
                                    <span>
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>
                                        @r.TypeKitchen
                                    </span>
                                </div>
                                <div class="gp-recipe-card-calories">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2c0 6-8 10-8 14a8 8 0 0 0 16 0c0-4-8-8-8-14z"/></svg>
                                    @r.CaloriesPerServing.ToString("F0") kcal / serving
                                </div>
                            </div>
                        </div>
                    </a>
                }
            </div>
        </NotAuthorized>
    </AuthorizeView>
}

@code {
    private List<Recipe>? recipes;
    private List<MealSlot> mealSlots = new();
    private string? errorMessage;
    private string searchText = "";
    private string selectedKitchenType = "";
    private int selectedMealSlotId = 0;

    private string SearchText
    {
        get => searchText;
        set { searchText = value; _ = Search(); }
    }

    protected override async Task OnInitializedAsync()
    {
        mealSlots = await MealSlotService.GetAllMealSlots();
        await Search();
    }

    private async Task Search()
    {
        try
        {
            KitchenType? kt = string.IsNullOrEmpty(selectedKitchenType) ? null : Enum.Parse<KitchenType>(selectedKitchenType);
            int? slotId = selectedMealSlotId == 0 ? null : selectedMealSlotId;
            recipes = await RecipeService.SearchRecipesAsync(searchText, kt, slotId, null, null);
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private string? confirmMessage;
    private int? pendingDeleteId;

    private void AskDeleteRecipe(int id) { pendingDeleteId = id; confirmMessage = "Are you sure you want to delete this recipe?"; }
    private async Task ConfirmDelete()
    {
        if (pendingDeleteId.HasValue) { await RecipeService.DeleteRecipe(pendingDeleteId.Value); await Search(); }
        pendingDeleteId = null; confirmMessage = null;
    }
    private void CancelDelete() { pendingDeleteId = null; confirmMessage = null; }
}