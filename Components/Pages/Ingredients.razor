@page "/ingredients"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject IIngredientService IngredientService
@inject NavigationManager NavigationManager

<PageTitle>Ingredients — GreenPlate</PageTitle>

<HeadContent>
    <style>
        .gp-thumb { width:44px; height:44px; border-radius:8px; object-fit:cover; border:1px solid #ddeae1; }
        .gp-thumb-placeholder { width:44px; height:44px; border-radius:8px; background:#f5f8f6; border:1px solid #ddeae1; display:flex; align-items:center; justify-content:center; color:#9aad9e; }
        .gp-thumb-placeholder svg { width:18px; height:18px; }
        .gp-action-btns { display:flex; gap:0.375rem; flex-wrap:wrap; }
        .gp-spin { animation: gp-spin 1s linear infinite; }
        @@keyframes gp-spin { to { transform: rotate(360deg); } }
    </style>
</HeadContent>

<div class="gp-page-header">
    <div>
        <h2>Ingredients</h2>
        <p>Manage your ingredient library</p>
    </div>
    <a href="/edit-ingredient" class="gp-btn gp-btn-green">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add Ingredient
    </a>
</div>

<div class="gp-search-wrapper" style="max-width:340px;margin-bottom:1.5rem;">
    <svg class="gp-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="text" @bind="searchText" @bind:event="oninput" class="gp-form-control gp-search-input" placeholder="Search ingredients..." />
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="gp-alert gp-alert-danger">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        @errorMessage
    </div>
}

@if (ingredients == null)
{
    <div class="gp-loading">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="gp-spin"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
        Loading ingredients...
    </div>
}
else
{
    <div class="gp-card" style="overflow:hidden;">
        <table class="gp-table">
            <thead>
                <tr><th>Image</th><th>Name</th><th>Calories / 100g</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @if (!FilteredIngredients.Any())
                {
                    <tr><td colspan="4" style="text-align:center;padding:2rem;color:#6b7c72;">No ingredients found.</td></tr>
                }
                @foreach (var ing in FilteredIngredients)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(ing.ImagePath))
                            {
                                <img src="@ing.ImagePath" class="gp-thumb" />
                            }
                            else
                            {
                                <div class="gp-thumb-placeholder"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>
                            }
                        </td>
                        <td style="font-weight:500;color:#1a2e20;">@ing.NameIng</td>
                        <td><span class="gp-badge gp-badge-amber">@ing.CaloriesPer100g kcal</span></td>
                        <td>
                            <div class="gp-action-btns">
                                <a href="/edit-ingredient/@ing.IdIng" class="gp-btn gp-btn-outline-green" style="padding:0.35rem 0.75rem;font-size:0.8rem;">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit
                                </a>
                                <button class="gp-btn gp-btn-outline-red" style="padding:0.35rem 0.75rem;font-size:0.8rem;" @onclick="() => DeleteIngredient(ing.IdIng)">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg> Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Ingredient>? ingredients;
    private string searchText = "";
    private string? errorMessage;

    private List<Ingredient> FilteredIngredients =>
        ingredients?.Where(i => string.IsNullOrEmpty(searchText) ||
                                i.NameIng.Contains(searchText, StringComparison.OrdinalIgnoreCase))
                   .ToList() ?? new();

    protected override async Task OnInitializedAsync()
    {
        ingredients = await IngredientService.GetAllIngredients();
    }

    private async Task DeleteIngredient(int id)
    {
        try { errorMessage = null; await IngredientService.DeleteIngredient(id); ingredients = await IngredientService.GetAllIngredients(); }
        catch (Exception ex) { errorMessage = ex.Message; }
    }
}