@page "/ingredients"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject IIngredientService IngredientService
@inject NavigationManager NavigationManager
<h3>Ingredient Management</h3>
<a href="/edit-ingredient" class="btn btn-success mb-3">
    <i class="bi bi-plus-circle"></i> Add Ingredient
</a>

<div class="mb-3">
    <div class="input-group">
        <span class="input-group-text"><i class="bi bi-search"></i></span>
        <input type="text"
               @bind="searchText"
               @bind:event="oninput"
               class="form-control"
               placeholder="Search by name..." />
    </div>
</div>

@if (ingredients == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Calories / 100g</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!FilteredIngredients.Any())
            {
                <tr><td colspan="4" class="text-center">No ingredients found.</td></tr>
            }
            @foreach (var ing in FilteredIngredients)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(ing.ImagePath))
                        {
                            <img src="@ing.ImagePath" style="width:50px;height:50px;object-fit:cover;" class="rounded" />
                        }
                        else
                        {
                            <i class="bi bi-image text-muted fs-4"></i>
                        }
                    </td>
                    <td>@ing.NameIng</td>
                    <td>@ing.CaloriesPer100g kcal</td>
                    <td>
                        <a href="/edit-ingredient/@ing.IdIng" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => DeleteIngredient(ing.IdIng)">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@code {
    private List<Ingredient>? ingredients;
    private string searchText = "";
    private string? errorMessage;

    private List<Ingredient> FilteredIngredients =>
        ingredients?.Where(i => string.IsNullOrEmpty(searchText) ||
                                i.NameIng.Contains(searchText, StringComparison.OrdinalIgnoreCase))
                   .ToList() ?? new();

    protected override async Task OnInitializedAsync()
    {
        ingredients = await IngredientService.GetAllIngredients();
    }

    private async Task DeleteIngredient(int id)
    {
        try
        {
            errorMessage = null;
            await IngredientService.DeleteIngredient(id);
            ingredients = await IngredientService.GetAllIngredients();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}