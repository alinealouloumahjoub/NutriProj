<div class="gp-sidebar-brand">
    <a href="/" class="gp-brand-link">
        <svg class="gp-logo-svg" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="24" cy="24" r="22" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" fill="rgba(255,255,255,0.08)"/>
            <path d="M14 28c0-5.5 4.5-10 10-10s10 4.5 10 10" stroke="white" stroke-width="2" stroke-linecap="round"/>
            <path d="M24 18v-6M20 15l4-3 4 3" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="24" cy="31" r="4" fill="white" opacity="0.9"/>
            <path d="M17 34h14" stroke="white" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <span class="gp-brand-text">GreenPlate</span>
    </a>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="gp-nav">
        <AuthorizeView>
            <Authorized>
                <div class="gp-nav-section">
                    <span class="gp-nav-section-label">Main</span>
                    <NavLink class="gp-nav-link" href="recipes" Match="NavLinkMatch.Prefix">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                        Recipes
                    </NavLink>
                    <NavLink class="gp-nav-link" href="meal-planner" Match="NavLinkMatch.Prefix">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        Meal Planner
                    </NavLink>
                </div>

                <AuthorizeView Roles="Admin" Context="adminCtx">
                    <Authorized>
                        <div class="gp-nav-section">
                            <span class="gp-nav-section-label">Admin</span>
                            <NavLink class="gp-nav-link" href="ingredients" Match="NavLinkMatch.Prefix">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                                Ingredients
                            </NavLink>
                            <NavLink class="gp-nav-link" href="dashboard" Match="NavLinkMatch.Prefix">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                                Dashboard
                            </NavLink>
                        </div>
                    </Authorized>
                </AuthorizeView>

                <div class="gp-nav-bottom">
                    <div class="gp-user-info">
                        <div class="gp-user-avatar">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        </div>
                        <div class="gp-user-details">
                            <span class="gp-user-name">@context.User.Identity?.Name</span>
                            <span class="gp-user-role">Member</span>
                        </div>
                    </div>
                    <form method="post" action="/api/auth/logout" data-enhance="false">
                        <button type="submit" class="gp-logout-btn">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                            Sign out
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="gp-nav-section">
                    <span class="gp-nav-section-label">Account</span>
                    <NavLink class="gp-nav-link" href="login">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                        Sign in
                    </NavLink>
                    <NavLink class="gp-nav-link" href="inscription">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                        Create account
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>
